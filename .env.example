# Copy this to .env and adjust values for your setup

# Serial Connection
PIXHAWK_PORT=/dev/ttyAMA0
PIXHAWK_BAUD=57600

# Server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=0

# Data Logging
DATA_DIR=./data
LOG_LEVEL=INFO

# Optional: ROS2
ROS_DOMAIN_ID=0
ROS_LOCALHOST_ONLY=0

# Optional: LiDAR
LIVOX_PORT=/dev/ttyUSB0
LIVOX_ENABLED=0

# Optional: Edge TPU
TPU_MODEL_PATH=./models/mobilenet_v2_1.0_224_inat_bird_quant_edgetpu.tflite
TPU_ENABLED=0
